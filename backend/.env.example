# Backend secrets — copy this to backend/.env and fill in. (.env is gitignored.)
# The app runs WITHOUT any of these (it uses built-in fallbacks); keys upgrade fidelity.

# OneMap — free account at https://www.onemap.gov.sg  (real SG geocoding + walking routes)
ONEMAP_EMAIL=
ONEMAP_PASSWORD=

# Gemini — free key at https://aistudio.google.com  (the AI decision engine)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Google Maps — Street View Static API key (enable billing; the recurring monthly free
# quota covers demo usage). Gives real street-level landmark photos. Without it, cards show icons.
GOOGLE_MAPS_KEY=

# Comma-separated origins allowed to call the API.
# Local dev default below; in production set this to your frontend URL (or "*" to allow all).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
